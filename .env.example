# ===== Meta Marketing API (Phase A: founder account) =====
# App: dev console → My Apps ("My Insta Manager") → App settings → Basic
META_APP_ID=
META_APP_SECRET=
# Long-lived token: get short-lived from Marketing API → Tools → Get Token
# (ads_management, ads_read, read_insights), then:
#   python scripts/ads/exchange_token.py --token <SHORT_TOKEN>
META_ACCESS_TOKEN=
# Target ad account: act_<number> (real) — or sandbox account id for risk-free tests
META_AD_ACCOUNT_ID=
# The Facebook Page ads post as
META_PAGE_ID=
META_GRAPH_API_VERSION=v23.0

# ===== Safety rails =====
# Hard cap on daily budget, minor currency units (50000 = $500.00 / ₹500.00)
ADS_MAX_DAILY_BUDGET_CENTS=50000
# Firebase UID that owns founder launches (Phase B UI shows them under this user)
FOUNDER_USER_ID=founder

# ===== Shared Firebase/GCP project (same values as IgniteAI .env) =====
# One of: FIREBASE_SERVICE_ACCOUNT_JSON (inline JSON), FIREBASE_SERVICE_ACCOUNT_PATH, or ADC
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_STORAGE_BUCKET=

# ===== AI copy =====
GEMINI_API_KEY=
# ADS_COPY_MODEL=gemini-2.5-flash

# ===== Phase B (leave empty for now) =====
# ADS_TOKEN_ENC_KEY=          # Fernet key for customer token encryption
# CLOUD_TASKS_QUEUE=          # projects/<P>/locations/<R>/queues/ignite-ads-jobs
# CLOUD_RUN_URL=
# CLOUD_TASKS_SA_EMAIL=
# CORS_ORIGINS=http://localhost:4200
